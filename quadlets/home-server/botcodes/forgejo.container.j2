[Unit]
Description=Forgejo Quadlet

[Container]
ContainerName=forgejo
Image=codeberg.org/forgejo/forgejo:14-rootless
Network=botcodes.network

UserNS=keep-id

Volume=%h/.local/containers/forgejo/data:/var/lib/gitea:rw
Volume=%h/.local/containers/forgejo/conf:/etc/gitea:rw

Environment=FORGEJO__server__DOMAIN={{ forgejo_server_domain }}
Environment=FORGEJO__server__ROOT_URL={{ forgejo_server_root_url }}
Environment=FORGEJO__server__SSH_DOMAIN={{ forgejo_server_ssh_domain }}
Environment=FORGEJO__server__SSH_PORT={{ forgejo_server_ssh_port }}
Environment=FORGEJO__server__START_SSH_SERVER={{ forgejo_server_start_ssh_server }}
Environment=FORGEJO__server__SSH_LISTEN_PORT={{ forgejo_server_ssh_listen_port }}

PublishPort={{ forgejo_server_ssh_listen_port }}:{{ forgejo_server_ssh_listen_port }}

[Service]
Restart=always

[Install]
WantedBy=default.target
