server {
	listen 443 ssl;
	server_name rss.botcodes.dev;

  ssl_certificate     /etc/letsencrypt/live/rss.botcodes.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/rss.botcodes.dev/privkey.pem;

	location / {
		include snippets/authelia-authrequest.conf;

        proxy_pass http://miniflux-app:8010;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
	}

	include snippets/authelia-location.conf;

}