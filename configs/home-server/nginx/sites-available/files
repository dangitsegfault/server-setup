server {
	listen 443 ssl;
	server_name files.botcodes.dev;

  ssl_certificate     /etc/letsencrypt/live/files.botcodes.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/files.botcodes.dev/privkey.pem;

	client_max_body_size 100M;

    resolver 10.0.0.1 valid=10s;
    set $backend http://filebrowser:8002;

	location / {
		include snippets/authelia-authrequest.conf;

		proxy_pass $backend;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;

		proxy_request_buffering off;
	}

	include snippets/authelia-location.conf;

}