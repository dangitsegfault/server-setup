server {
  listen 443 ssl;
	server_name search.botcodes.dev;

  ssl_certificate     /etc/letsencrypt/live/search.botcodes.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/search.botcodes.dev/privkey.pem;

  resolver 10.0.0.1 valid=10s;
  set $backend http://searxng:8080;

	location / {
		proxy_pass $backend;
		proxy_set_header Host $host;
		proxy_set_header X-Real-IP $remote_addr;
	}

}