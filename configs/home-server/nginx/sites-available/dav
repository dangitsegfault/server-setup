server {
	listen 443 ssl;
	server_name dav.botcodes.dev;

  ssl_certificate     /etc/letsencrypt/live/dav.botcodes.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/dav.botcodes.dev/privkey.pem;

	location = /.well-known/caldav {
		return 302 /;
	}

	location = /.well-known/carddav {
		return 302 /;
	}

    resolver 10.0.0.1 valid=10s;
    set $backend http://radicale:5232;

	location / {
		proxy_pass $backend;
		proxy_set_header  X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header  X-Forwarded-Host $host;
		proxy_set_header  X-Forwarded-Port $server_port;
		proxy_set_header  X-Forwarded-Proto $scheme;
		proxy_set_header  Host $http_host;
		proxy_pass_header Authorization;
	}
}