server {
  listen 443 ssl;
  server_name auth.botcodes.dev;

  ssl_certificate     /etc/letsencrypt/live/auth.botcodes.dev/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/auth.botcodes.dev/privkey.pem;

  resolver 10.0.0.1 valid=10s;
  set $backend http://authelia:8006;

  location / {
    proxy_pass $backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}