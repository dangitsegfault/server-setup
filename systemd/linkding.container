[Unit]
Description=Linking Quadlet
Requires=nginx.service
After=nginx.service

[Container]
ContainerName=linkding
Image=docker.io/sissbruecker/linkding:latest
Pod=botcodes.pod

Volume=%h/.local/containers/linkding:/etc/linkding/data
Environment=LD_SERVER_PORT=8009

[Service]
Restart=always

[Install]
WantedBy=default.target
